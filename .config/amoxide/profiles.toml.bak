[[profiles]]
name = "git"

[profiles.aliases]
ga = "git add"
gai = "git add -i"
gap = "git add -p"
gb = "git branch"
gba = "git branch --all"
gbas = "git branch --all --sort=-committerdate"
gc! = "git commit --amend -v"
gc = "git commit -v"
gca! = "git commit -av --amend"
gca = "git commit -av"
gcf = "git commit --fixup=$1"
gd = "git diff"
gdc = "git diff --cached"
gdh = "git diff @"
gds = "git diff --staged"
gdsw = "git diff --staged --word-diff"
gdt = "git difftool"
gdw = "git diff --word-diff"
gfa = "git fetch --all"
ghh = "git hist"
gha = "git hist --all"
gk = "gitk --all&"
gm = "git merge"
gmf = "git merge --ff-only"
go- = "git checkout -"
go = "git checkout"
gp = "git push"
gpf = "git push --force-with-lease"
gpr = "git pull --rebase --autostash"
gr = "git reset"
grb = "git rebase"
grh = "git reset --hard"
gri = "git rebase -i --autosquash"
grs = "git reset --soft"
gs = "git status"
gsb = "git status -sb"
gtags = "git tag --sort='v:refname'"
gx = "gitx --all"
